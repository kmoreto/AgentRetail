<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
  <Popover id="supplierAlertsPopover" placement="Top" title="Alertas do fornecedor">
    <List items="{alerts>/items}">
      <CustomListItem>
        <VBox class="sapUiSmallMargin">
          <HBox alignItems="Center" justifyContent="SpaceBetween" class="sapUiTinyMarginBottom">
            <HBox alignItems="Center">
              <core:Icon src="{alerts>icon}" class="sapUiTinyMarginEnd" size="1rem"/>
              <!-- era <Text design="Bold"...> -->
              <Title text="{alerts>title}" level="H6"/>
            </HBox>
            <ObjectStatus text="{alerts>days} " state="{alerts>state}"/>
          </HBox>
          <Text text="{alerts>subtitle}"/>
        </VBox>
      </CustomListItem>
    </List>
  </Popover>
</core:FragmentDefinition>
